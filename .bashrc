HISTSIZE=10000
HISTFILESIZE=20000

# some more ls aliases
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
alias c='clear'
alias e='exit'
alias ff='fastfetch'
alias mygitlog='git log --oneline --graph --all'
alias myenv='python3 -m venv .venv && source .venv/bin/activate'
alias up='sudo nala update && sudo nala upgrade -y'
alias ws='gsettings set org.gnome.desktop.wm.preferences num-workspaces'
